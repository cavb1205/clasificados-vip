# Copiar a .env y completar. Generar claves con:
#   SECRET: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   FERNET: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

KYC_ENCRYPTION_KEY=

# POSTGRES_DB=clasificados_vip
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Email / notificaciones al admin.
# En dev se imprime en stdout del runserver. En prod usar SMTP real.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@clasificados.vip
# Lista separada por comas de emails que reciben notificaciones (KYC, pagos, reseñas).
DJANGO_ADMIN_EMAILS=
