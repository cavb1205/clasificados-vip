# Plantilla para producción. Copiar a .env.production y completar valores reales.
# NO commitear .env.production (está en .gitignore).

# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRÍTICO: si pierdes esta clave, los KYC cifrados existentes no se pueden descifrar.
KYC_ENCRYPTION_KEY=

DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api-165-22-154-95.sslip.io,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://api-165-22-154-95.sslip.io
CORS_ALLOWED_ORIGINS=https://clasificados-vip.vercel.app

# Postgres: conecta al contenedor ya existente del stack EasyPanel.
POSTGRES_DB=vip_db
POSTGRES_USER=vip
POSTGRES_PASSWORD=
POSTGRES_HOST=n8n_evolution-api-db
POSTGRES_PORT=5432

# JWT cookies (HttpOnly + Secure en HTTPS real).
JWT_COOKIE_SECURE=True
JWT_COOKIE_SAMESITE=None

# Email — para empezar, console; reemplazar con SMTP real cuando tengas dominio.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@clasificados.vip
DJANGO_ADMIN_EMAILS=cavb.1205@hotmail.com

LOG_LEVEL=INFO
